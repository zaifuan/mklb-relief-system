# ════════════════════════════════════════════════════
#  Sistem Auto Jana Jadual Guru Ganti — .env
#  Salin ke .env dan isi nilai sebenar
# ════════════════════════════════════════════════════

# ── Database (PostgreSQL) ──
POSTGRES_USER=relief
POSTGRES_PASSWORD=tukar_password_kuat_ini
POSTGRES_DB=relief_db
DATABASE_URL=postgresql://relief:tukar_password_kuat_ini@relief-postgres:5432/relief_db?schema=public

# ── Backend ──
NODE_ENV=production
BACKEND_PORT=4000
JWT_SECRET=tukar_kepada_rentetan_rawak_panjang
JWT_EXPIRES_IN=8h
SEED_DEFAULT_PASSWORD=ubah1234        # kata laluan awal semua admin (TUKAR selepas login)
SEED_ON_START=true                    # set 'false' selepas seed pertama berjaya

# ── CORS / Domain ──
FRONTEND_BORANG_ORIGIN=https://borangketidakhadiranguru.byzaifuan.com
FRONTEND_ADMIN_ORIGIN=https://adminjadual.byzaifuan.com

# ── Frontend ──
# NEXT_PUBLIC_API_URL = ORIGIN backend (TANPA /api). Dibaked pada masa build frontend.
# Ujian lokal:
NEXT_PUBLIC_API_URL=http://localhost:4000
# Prod (Fasa 9): https://adminjadual.byzaifuan.com
FRONTEND_BORANG_PORT=3001
FRONTEND_ADMIN_PORT=3002

# ── Zon masa ──
TZ=Asia/Kuala_Lumpur

# ── Google Sheets Sync (Fasa 3) ──
# Service account: cipta di GCP → enable Sheets API → kongsi Google Sheet (Viewer) dengan emel SA.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Tampal private key dalam SATU baris, guna \n untuk baris baru, dalam petikan. Contoh:
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=
# Nama tab (laras ikut sheet sebenar):
SHEET_TAB_GURU=KATEGORI GURU
SHEET_TAB_JADUAL=JADUAL GURU
SHEET_TAB_JADUAL_KELAS=JADUAL KELAS
SHEET_TAB_PENGECUALIAN=pengecualian_relief
SHEET_HEADER_ROW=1
# Set 'false' bila pengecualian diurus melalui panel (supaya tab ini tidak ditimpa):
SYNC_PENGECUALIAN=true

# ── Telegram (Fasa 8) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Cron / Penjadual (Fasa 9) ──
# ENABLE_SCHEDULER=false untuk matikan snapshot pagi auto (cth. semasa ujian)
ENABLE_SCHEDULER=true
# Rahsia untuk endpoint sandaran POST /api/telegram/cron/snapshot (header x-cron-secret)
CRON_SECRET=

# ── Cloudflare Tunnel (Fasa 9) ──
CLOUDFLARE_TUNNEL_TOKEN=
